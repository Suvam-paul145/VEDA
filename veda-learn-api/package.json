{
  "name": "veda-learn-api",
  "version": "1.0.0",
  "description": "AWS Lambda backend for Veda Learn - AI-powered code education",
  "main": "index.js",
  "scripts": {
    "deploy": "serverless deploy",
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:prod": "serverless deploy --stage prod",
    "remove": "serverless remove",
    "logs": "serverless logs -f",
    "invoke": "serverless invoke -f",
    "offline": "serverless offline",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "veda",
    "learn",
    "aws",
    "lambda",
    "serverless",
    "ai",
    "education"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1001.0",
    "@aws-sdk/client-bedrock-runtime": "^3.0.0",
    "@aws-sdk/client-dynamodb": "^3.1001.0",
    "@aws-sdk/client-polly": "^3.1001.0",
    "@aws-sdk/client-s3": "^3.1001.0",
    "@aws-sdk/lib-dynamodb": "^3.1001.0",
    "@aws-sdk/s3-request-presigner": "^3.1001.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@google/generative-ai": "^0.24.1",
    "@opensearch-project/opensearch": "^2.13.0",
    "@pinecone-database/pinecone": "^7.1.0",
    "aws4": "^1.13.2",
    "axios": "^1.6.0",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^2.7.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "serverless": "^3.40.0",
    "serverless-dotenv-plugin": "^6.0.0",
    "serverless-offline": "^13.9.0"
  },
  "directories": {
    "lib": "lib"
  },
  "type": "commonjs"
