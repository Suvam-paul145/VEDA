{
  "name": "veda-learn",
  "displayName": "Veda Learn",
  "description": "AI-powered code education that teaches you why, not just fixes",
  "version": "1.0.0",
  "publisher": "veda-learn",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Education",
    "Machine Learning",
    "Linters"
  ],
  "keywords": [
    "ai",
    "learning",
    "education",
    "code-quality",
    "mentor"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "veda",
          "title": "Veda Learn",
          "icon": "$(mortar-board)"
        }
      ]
    },
    "views": {
      "veda": [
        {
          "type": "webview",
          "id": "veda.sidebar",
          "name": "Veda Learn"
        }
      ]
    },
    "commands": [
      {
        "command": "veda.login",
        "title": "Veda: Sign in with GitHub"
      },
      {
        "command": "veda.logout",
        "title": "Veda: Sign out"
      }
    ],
    "configuration": {
      "title": "Veda Learn",
      "properties": {
        "veda.demoMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable demo mode (5-second debounce instead of 30 seconds)"
        },
        "veda.apiEndpoint": {
          "type": "string",
          "default": "",
          "description": "Custom API endpoint (leave empty for default)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "ws": "^8.14.0"
  }
}
