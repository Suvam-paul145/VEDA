{
  "name": "veda",
  "displayName": "VEDA - AI Debugging Assistant",
  "description": "Voice-Enabled Debugging Assistant: Talk to your code, see bugs visually, fix instantly",
  "version": "1.0.0",
  "publisher": "veda-team",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Debuggers", "Machine Learning"],
  "keywords": ["ai", "debugging", "voice", "diagram", "copilot", "assistant"],
  "icon": "images/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "veda.analyzeCode",
        "title": "VEDA: Analyze Current File",
        "icon": "$(bug)"
      },
      {
        "command": "veda.analyzeSelection",
        "title": "VEDA: Analyze Selected Code",
        "icon": "$(search)"
      },
      {
        "command": "veda.openPanel",
        "title": "VEDA: Open Debug Panel",
        "icon": "$(robot)"
      },
      {
        "command": "veda.startVoice",
        "title": "VEDA: Start Voice Mode",
        "icon": "$(mic)"
      }
    ],
    "keybindings": [
      {
        "command": "veda.analyzeCode",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d"
      },
      {
        "command": "veda.openPanel",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "veda.analyzeSelection",
          "when": "editorHasSelection",
          "group": "veda"
        },
        {
          "command": "veda.analyzeCode",
          "group": "veda"
        }
      ]
    },
    "configuration": {
      "title": "VEDA",
      "properties": {
        "veda.apiUrl": {
          "type": "string",
          "default": "https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/prod/analyze",
          "description": "Your VEDA API Gateway endpoint URL"
        },
        "veda.companionMode": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time companion monitoring as you type"
        },
        "veda.voiceEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable voice responses from VEDA"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
