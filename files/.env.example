# ─── VEDA Lambda — Environment Variables ─────────────────────────────────────
# Copy this file: cp .env.example .env
# Fill in your values, then set them in AWS Lambda Console.
# NEVER commit .env to git — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# GCP Gemini API Key
# Get free key at: https://aistudio.google.com/app/apikey
# Used for: companion mode (real-time hints, ~400ms, 1500 RPM free)
GEMINI_API_KEY=AIzaSy_REPLACE_WITH_YOUR_KEY

# Node environment
NODE_ENV=production
